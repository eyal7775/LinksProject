pipeline {
    agent {
        docker {
            image 'python:3.10'
        }
    }
    stages {
        stage('Build') {
            steps {
                script {
                    hw = sh(script: 'python hello.py',returnStdout: true).trim()
                }
            }
        }
    }
}

